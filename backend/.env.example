# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/interviewAI?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=replace_with_a_strong_random_secret

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed frontend origins
# Example: https://yourapp.vercel.app,https://www.yourapp.com
ALLOWED_ORIGIN=http://localhost:5173

# Port (Render sets this automatically; leave blank for local dev)
# PORT=9001
